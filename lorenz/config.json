{
  "version": 1,
  "app": "lorenz",
  "description": "Lorenz and related strange attractors",

  "simulation": {
    "mode": "lorenz",
    "duration": 40.0,
    "timestep": 0.005,
    "lorenz":   { "sigma": 10.0, "rho": 28.0, "beta": 2.6667 },
    "rossler":  { "a": 0.2,  "b": 0.2,  "c": 5.7  },
    "initial_conditions": [0.1, 0.0, 0.0]
  },

  "sonification": {
    "pitch": { "min_hz": 80, "max_hz": 1200 },
    "spatial": { "pan_axis": "x" }
  },
  "animation": {
    "width": 600,
    "height": 600,
    "fps": 15,
    "trail_length": 200,
    "projection_axes": ["x", "z"]
  }
}